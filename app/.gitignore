# app/.gitignore
#
# The Capacitor android/ project itself is checked in (it is real source: the
# manifest, Gradle wiring, MainActivity, icons). Only its BUILD OUTPUT and
# machine-local files are ignored here. The Capacitor CLI also drops a fuller
# android/.gitignore inside the project; these entries mirror the important ones
# from the repo root so the artifacts stay ignored even if that file changes.

# Web build output consumed by `cap sync` (root .gitignore already covers
# app/dist, but keep it explicit here for anyone running commands from app/).
/dist

# Capacitor CLI caches.
.capacitor

# Android build artifacts (never committed - regenerated by Gradle).
android/build
android/app/build
android/.gradle
android/local.properties
android/.idea

# Web assets and config files that `cap sync` copies/generates into the native
# project from dist/ + capacitor.config.ts. They are derived, not source.
android/app/src/main/assets/public
android/app/src/main/assets/capacitor.config.json
android/app/src/main/res/xml/config.xml

# Signed/packaged binaries and signing material.
*.apk
*.aab
*.keystore
